# ──────────────────────────────────────────
# PACE RISE – Environment Variables
# ──────────────────────────────────────────
# 이 파일을 .env.local로 복사하여 실제 값을 입력하세요.
# cp .env.example .env.local

# ── Sanity CMS ──
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your-sanity-read-token

# ── Instagram API ──
# Instagram Basic Display API에서 발급받은 Long-lived Token
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# ── Resend (Email) ──
RESEND_API_KEY=your-resend-api-key
CONTACT_EMAIL_TO=pacerise.run@gmail.com

# ── Google Analytics ──
# GA4 Measurement ID (G-XXXXXXXXXX 형식)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site Config ──
NEXT_PUBLIC_SITE_URL=https://pace-rise.com
NEXT_PUBLIC_RECORDS_URL=https://records.pace-rise.com
